# Get API key from https://suno.com → Account → API (or https://sunoapi.org dashboard)
# Paste below, do NOT commit this file to git
SUNO_API_KEY=your_suno_api_key_here

# Optional: override base URL if you use a Suno API proxy
# Default works with the official Suno API
SUNO_API_BASE=https://api.suno.ai/v1
